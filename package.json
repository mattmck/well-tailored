{
  "name": "well-tailored",
  "version": "1.0.0",
  "description": "Job applications that actually fit. Resume + company + job description → tailored resume + cover letter, in parallel.",
  "type": "module",
  "bin": {
    "tailored": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts",
    "serve": "tsx src/cli.ts serve",
    "shots:workbench": "node scripts/capture-workbench-shots.mjs",
    "video:promo": "node scripts/build-workbench-promo.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattmck/well-tailored.git"
  },
  "keywords": [
    "resume",
    "cover-letter",
    "job-search",
    "tailoring",
    "ai",
    "openai"
  ],
  "author": "Matt McKnight <mcknight.matthew@gmail.com>",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "bugs": {
    "url": "https://github.com/mattmck/well-tailored/issues"
  },
  "homepage": "https://github.com/mattmck/well-tailored#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "marked": "^17.0.4",
    "openai": "^6.27.0",
    "react": "^19.2.4",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
