# AI provider — set ONE of the following groups.
# Provider priority: Gemini > Azure OpenAI > OpenAI > Anthropic

# ── Option 1: Google Gemini ───────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Option 2: Azure AI Foundry / Azure OpenAI ─────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-api-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini   # optional, defaults to gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-12-01-preview  # optional

# ── Option 3: OpenAI (or any OpenAI-compatible endpoint) ─────────────────────
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional override

# ── Option 4: Anthropic Claude ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model override (optional — defaults to the provider's recommended model)
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o

# Huntr API token — ONLY needed if you are NOT using huntr-cli.
# If you have huntr-cli installed and have run `huntr login`, credentials
# are picked up automatically from ~/.huntr/config.json or the system keychain.
# HUNTR_API_TOKEN=your-huntr-personal-token-here
